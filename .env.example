# e-Arzuhal Main Server Environment Variables
# Kopyala -> .env olarak kaydet ve değerleri doldur
# UYARI: .env dosyasını asla git'e commit etme!

# ── Ortam ───────────────────────────────────────────────────────────────────
# development | production
APP_ENV=development

# ── Veritabanı ──────────────────────────────────────────────────────────────
POSTGRES_DB_PASSWORD=your_postgres_password_here

# ── JWT ─────────────────────────────────────────────────────────────────────
# En az 64 karakter, güçlü rastgele değer
# Üretmek için: openssl rand -base64 64
JWT_SECRET=

# ── Microservis URL'leri (varsayılan: localhost) ─────────────────────────────
NLP_SERVICE_URL=http://localhost:8001
GRAPHRAG_SERVICE_URL=http://localhost:8000
STATISTICS_SERVICE_URL=http://localhost:8002
CHATBOT_SERVICE_URL=http://localhost:8003

# ── CORS (production'da frontend URL'lerini ekle) ───────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# ── Dahili API Anahtarı (Python servislerine gönderilir) ─────────────────────
# Python servislerindeki INTERNAL_API_KEY ile aynı değer olmalı
# Üretmek için: openssl rand -hex 32
INTERNAL_API_KEY=

# ── Auth rate limit (isteğe bağlı) ───────────────────────────────────────────
# Login: 10 istek / 60 saniye
AUTH_RATE_LIMIT_LOGIN_MAX_ATTEMPTS=10
AUTH_RATE_LIMIT_LOGIN_WINDOW_SECONDS=60
# Register: 5 istek / 3600 saniye
AUTH_RATE_LIMIT_REGISTER_MAX_ATTEMPTS=5
AUTH_RATE_LIMIT_REGISTER_WINDOW_SECONDS=3600
# Sadece güvenilir reverse proxy arkasında true yap
SECURITY_TRUST_FORWARDED_HEADERS=false

# ── Hibernate DDL (geliştirme: update | üretim: validate) ────────────────────
DDL_AUTO=update

# ── Swagger (geliştirme: true | üretim: false) ───────────────────────────────
SWAGGER_ENABLED=true

# ── Log seviyesi (geliştirme: DEBUG | üretim: INFO) ──────────────────────────
LOG_LEVEL_APP=DEBUG
